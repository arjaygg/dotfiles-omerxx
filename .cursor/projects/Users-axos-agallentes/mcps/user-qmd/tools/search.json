{
  "name": "search",
  "description": "Search by keyword. Finds documents containing exact words and phrases in the query.",
  "arguments": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Search query - keywords or phrases to find"
      },
      "limit": {
        "default": 10,
        "description": "Maximum number of results (default: 10)",
        "type": "number"
      },
      "minScore": {
        "default": 0,
        "description": "Minimum relevance score 0-1 (default: 0)",
        "type": "number"
      },
      "collection": {
        "description": "Filter to a specific collection by name",
        "type": "string"
      }
    },
    "required": [
      "query"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}