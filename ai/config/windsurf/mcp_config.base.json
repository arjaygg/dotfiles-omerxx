{
  "$schema": "https://json.schemastore.org/mcp.json",
  "mcpServers": {
    "pctx": {
      "command": "pctx",
      "args": [
        "mcp",
        "start",
        "--stdio",
        "-c",
        "${PCTX_CONFIG}"
      ]
    },
    "lean-ctx": {
      "command": "lean-ctx",
      "env": {
        "LEAN_CTX_DATA_DIR": "${LEAN_CTX_DATA_DIR}",
        "LEAN_CTX_FULL_TOOLS": "1"
      }
    }
  }
}
