{
  "$schema": "https://json.schemastore.org/mcp.json",
  "mcpServers": {
    "pctx": {
      "command": "pctx",
      "args": [
        "mcp",
        "start",
        "--stdio",
        "-c",
        "${PCTX_CONFIG}"
      ]
    },
    "notebooklm": {
      "command": "notebooklm-mcp",
      "args": []
    },
    "chrome-devtools": {
      "command": "chrome-devtools-mcp-wrapper.sh",
      "args": []
    }
  }
}
