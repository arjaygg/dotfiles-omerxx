{
  "name": "${USER_NAME}",
  "version": "0.1.0",
  "disclosure": "catalog",
  "servers": [
    {
      "name": "serena",
      "command": "serena",
      "args": [
        "--context",
        "claude-code",
        "--project-from-cwd",
        "--log-level",
        "ERROR"
      ]
    },
    {
      "name": "qmd",
      "command": "qmd",
      "args": ["mcp"]
    },
    {
      "name": "lean-ctx",
      "command": "lean-ctx",
      "args": ["mcp", "--stdio"],
      "env": {"LEAN_CTX_CACHE_TTL": "300"}
    },
    {
      "name": "repomix",
      "command": "repomix",
      "args": ["--mcp"]
    },
    {
      "name": "graphify",
      "command": "graphify-mcp-conditional",
      "args": []
    }
  ],
  "logger": {
    "enabled": false,
    "level": "error",
    "format": "compact",
    "colors": true
  },
  "telemetry": {
    "traces": {"enabled": false, "sampling": {"strategy": "always", "rate": 1.0}, "exporters": []},
    "metrics": {"enabled": false, "exporters": []}
  }
}
