{
  "name": "pctx-integration",
  "version": "0.1.0",
  "disclosure": "catalog",
  "servers": [
    {
      "name": "serena",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project",
        "/Users/agallentes/.dotfiles",
        "--open-web-dashboard",
        "False"
      ]
    },
    {
      "name": "exa",
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server",
        "--tools=web_search_exa,deep_search_exa,get_code_context_exa,crawling_exa,company_research_exa,linkedin_search_exa,deep_researcher_start,deep_researcher_check"
      ],
      "env": {
        "EXA_API_KEY": "${env:EXA_API_KEY}"
      }
    },
    {
      "name": "sequential-thinking",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    {
      "name": "notebooklm",
      "command": "uvx",
      "args": ["--from", "notebooklm-mcp-cli", "notebooklm-mcp"]
    },
    {
      "name": "markitdown",
      "command": "markitdown-mcp",
      "args": []
    }
  ],
  "logger": {
    "enabled": true,
    "level": "info",
    "format": "compact",
    "colors": true
  },
  "telemetry": {
    "traces": {
      "enabled": false,
      "sampling": {
        "strategy": "always",
        "rate": 1.0
      },
      "exporters": []
    },
    "metrics": {
      "enabled": false,
      "exporters": []
    }
  }
}
