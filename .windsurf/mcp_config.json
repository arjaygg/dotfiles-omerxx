{
  "mcpServers": {
    "pctx": {
      "command": "pctx",
      "args": [
        "mcp",
        "start",
        "--stdio",
        "-c",
        "pctx.json"
      ],
      "env": {}
    },
    "notebooklm": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "notebooklm-mcp-cli"
      ],
      "env": {}
    }
  }
}
