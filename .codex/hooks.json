{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.codex/hooks/session-start.sh\"'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.codex/hooks/user-prompt-submit.sh\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|shell_command|exec_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.codex/hooks/pre-bash-guard.sh\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|shell_command|exec_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.codex/hooks/post-bash-observe.sh\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.codex/hooks/stop.sh\"'"
          }
        ]
      }
    ]
  }
}
