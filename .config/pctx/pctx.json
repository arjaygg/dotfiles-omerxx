{
  "name": "${env:USER}",
  "version": "0.1.0",
  "disclosure": "catalog",
  "servers": [
    {
      "name": "serena",
      "command": "/Users/axos-agallentes/.local/bin/serena_wrapper.sh",
      "args": [
        "--context",
        "claude-code",
        "--project-from-cwd",
        "--log-level",
        "ERROR"
      ]
    },
    {
      "name": "qmd",
      "command": "/opt/homebrew/bin/qmd",
      "args": [
        "mcp"
      ],
      "env": {
        "PATH": "/opt/homebrew/bin:/Users/axos-agallentes/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    {
      "name": "lean-ctx",
      "command": "/Users/axos-agallentes/.cargo/bin/lean-ctx",
      "args": [
        "mcp",
        "--stdio"
      ],
      "env": {
        "LEAN_CTX_CACHE_TTL": "300"
      }
    },
    {
      "name": "repomix",
      "command": "/Users/axos-agallentes/homebrew/bin/repomix",
      "args": [
        "--mcp"
      ]
    },
    {
      "name": "graphify",
      "command": "/Users/axos-agallentes/.local/bin/graphify-mcp-conditional",
      "args": []
    }
  ],
  "logger": {
    "enabled": false,
    "level": "error",
    "format": "compact",
    "colors": true
  },
  "telemetry": {
    "traces": {
      "enabled": false,
      "sampling": {
        "strategy": "always",
        "rate": 1.0
      },
      "exporters": []
    },
    "metrics": {
      "enabled": false,
      "exporters": []
    }
  }
}