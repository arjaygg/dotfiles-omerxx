{
  "name": "${env:USER}",
  "version": "0.1.0",
  "disclosure": "catalog",
  "servers": [
    {
      "name": "serena",
      "command": "/Users/axos-agallentes/.local/bin/serena_wrapper.sh",
      "args": [
        "--context",
        "claude-code",
        "--project-from-cwd",
        "--log-level",
        "ERROR"
      ]
    },
    {
      "name": "qmd",
      "command": "/Users/axos-agallentes/.bun/bin/qmd",
      "args": [
        "mcp"
      ]
    },
    {
      "name": "lean-ctx",
      "command": "/Users/axos-agallentes/.cargo/bin/lean-ctx",
      "args": [
        "mcp",
        "--stdio"
      ],
      "env": {
        "LEAN_CTX_CACHE_TTL": "300"
      }
    },
    {
      "name": "repomix",
      "command": "repomix",
      "args": [
        "--mcp"
      ]
    }
  ],
  "logger": {
    "enabled": false,
    "level": "error",
    "format": "compact",
    "colors": true
  }
}