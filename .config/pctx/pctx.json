{
  "name": "${env:USER}",
  "version": "0.1.0",
  "disclosure": "catalog",
  "servers": [
    {
      "name": "serena",
      "command": "/Users/axos-agallentes/.local/bin/serena_wrapper.sh",
      "args": [
        "--context",
        "claude-code",
        "--project-from-cwd",
        "--log-level",
        "ERROR"
      ]
    },
    {
      "name": "exa",
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server",
        "--tools=web_search_exa,deep_search_exa,get_code_context_exa,crawling_exa,company_research_exa,linkedin_search_exa,deep_researcher_start,deep_researcher_check"
      ],
      "env": {
        "EXA_API_KEY": "${env:EXA_API_KEY}"
      }
    },
    {
      "name": "sequential-thinking",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    {
      "name": "qmd",
      "command": "qmd",
      "args": [
        "mcp"
      ]
    },
    {
      "name": "Ref",
      "url": "https://api.ref.tools/mcp",
      "auth": {
        "type": "headers",
        "headers": {
          "x-ref-api-key": "ref-e12567ea1d5b4c4bb0c8"
        }
      }
    },
    {
      "name": "context-mode",
      "command": "npx",
      "args": [
        "-y",
        "context-mode"
      ]
    },
    {
      "name": "voice-mode",
      "command": "voice-mode"
    },
    {
      "name": "notebooklm",
      "command": "notebooklm-mcp",
      "args": []
    },
    {
      "name": "markitdown",
      "command": "markitdown-mcp",
      "args": []
    },
    {
      "name": "lean-ctx",
      "command": "/Users/axos-agallentes/.cargo/bin/lean-ctx",
      "args": ["mcp", "--stdio"],
      "env": { "LEAN_CTX_CACHE_TTL": "300" }
    }
  ],
  "logger": {
    "enabled": false,
    "level": "error",
    "format": "compact",
    "colors": true
  }
}
