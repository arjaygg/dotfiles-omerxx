{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "USE_BUILTIN_RIPGREP": "0"
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Agent(*)",
      "Skill(*)",
      "ToolSearch(*)",
      "AskUserQuestion(*)",
      "EnterPlanMode(*)",
      "ExitPlanMode(*)",
      "EnterWorktree(*)",
      "ExitWorktree(*)",
      "NotebookEdit(*)",
      "CronCreate(*)",
      "CronDelete(*)",
      "CronList(*)",
      "RemoteTrigger(*)",
      "TaskCreate(*)",
      "TaskGet(*)",
      "TaskList(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "TaskUpdate(*)",
      "mcp__*__*"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * -O- | sh)",
      "Bash(wget * | bash)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(kill -9 *)",
      "Bash(find * -delete*)",
      "Bash(shred *)",
      "Bash(dd if=*)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./secrets/**)",
      "Read(~/.ssh/*)",
      "Edit(~/.ssh/*)",
      "Write(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Edit(~/.aws/*)",
      "Write(~/.aws/*)",
      "Read(~/.gnupg/**)",
      "Edit(~/.gnupg/**)",
      "Write(~/.gnupg/**)",
      "mcp__notebooklm__notebookDelete(*)",
      "mcp__notebooklm__sourceDelete(*)",
      "mcp__notebooklm__studioDelete(*)"
    ],
    "defaultMode": "auto"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/session-init.sh\"'"
          },
          {
            "type": "command",
            "command": "/Users/axos-agallentes/homebrew/bin/node /Users/axos-agallentes/homebrew/lib/node_modules/context-mode/hooks/sessionstart.mjs"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/instructions-loaded.sh\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/pre-tool-gate.sh\"'"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/check-agent-parallelism.sh\"'"
          }
        ]
      },
      {
        "matcher": "Bash|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/axos-agallentes/homebrew/bin/node /Users/axos-agallentes/homebrew/lib/node_modules/context-mode/hooks/pretooluse.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/post-tool-handler.sh\"'"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/axos-agallentes/homebrew/bin/node /Users/axos-agallentes/homebrew/lib/node_modules/context-mode/hooks/posttooluse.mjs"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/context-monitor.sh\"'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/qmd-sync.sh\"'"
          },
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/plans-healthcheck.sh\"'"
          },
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/prompt-parallelism-hint.sh\"'"
          },
          {
            "type": "command",
            "command": "/Users/axos-agallentes/homebrew/bin/node /Users/axos-agallentes/homebrew/lib/node_modules/context-mode/hooks/userpromptsubmit.mjs"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/pre-compact.sh\"'"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/axos-agallentes/homebrew/bin/node /Users/axos-agallentes/homebrew/lib/node_modules/context-mode/hooks/precompact.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/session-end.sh\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/claude-statusline/statusline.sh"
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {},
  "alwaysThinkingEnabled": true,
  "plansDirectory": "plans",
  "autoMode": {
    "environment": [
      "Organization: Axos Financial / Axos Bank. Primary use: software development.",
      "Source control: dev.azure.com/bofaz and bofaz.visualstudio.com — all repos and projects under these organizations.",
      "Key projects: Axos-Universal-Core, Axos Clearing, Axos Core Services, Axos-Crypto-Core, AAS, AxPay, AxTrader, Stock Lending Services.",
      "Azure DevOps CLI org: https://dev.azure.com/bofaz. PR creation org: https://bofaz.visualstudio.com.",
      "Local development: macOS, git worktrees under .trees/, homebrew at /Users/axos-agallentes/homebrew/."
    ]
  },
  "mcpServers": {
    "pctx": {
      "command": "pctx",
      "args": [
        "mcp",
        "start",
        "--stdio",
        "-c",
        "${env:HOME}/.config/pctx/pctx.json"
      ]
    }
  }
}
