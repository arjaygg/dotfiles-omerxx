{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "USE_BUILTIN_RIPGREP": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Read(/Users/axos-agallentes/.dotfiles/**)",
      "Write(*)",
      "Write(/Users/axos-agallentes/.dotfiles/**)",
      "Edit(*)",
      "Edit(/Users/axos-agallentes/.dotfiles/**)",
      "Glob(*)",
      "Grep(*)",
      "Bash(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Agent(*)",
      "Skill(*)",
      "ToolSearch(*)",
      "AskUserQuestion(*)",
      "EnterPlanMode(*)",
      "ExitPlanMode(*)",
      "EnterWorktree(*)",
      "ExitWorktree(*)",
      "NotebookEdit(*)",
      "CronCreate(*)",
      "CronDelete(*)",
      "CronList(*)",
      "RemoteTrigger(*)",
      "TaskCreate(*)",
      "TaskGet(*)",
      "TaskList(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "TaskUpdate(*)",
      "mcp__*__*"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * -O- | sh)",
      "Bash(wget * | bash)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(kill -9 *)",
      "Bash(find * -delete*)",
      "Bash(shred *)",
      "Bash(dd if=*)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./secrets/**)",
      "Read(~/.ssh/*)",
      "Edit(~/.ssh/*)",
      "Write(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Edit(~/.aws/*)",
      "Write(~/.aws/*)",
      "Read(~/.gnupg/**)",
      "Edit(~/.gnupg/**)",
      "Write(~/.gnupg/**)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(grep -*)",
      "Bash(find . *)",
      "Bash(find / *)",
      "Read(**/package-lock.json)",
      "Read(**/yarn.lock)",
      "Read(**/Cargo.lock)",
      "Read(**/pnpm-lock.yaml)",
      "Read(**/composer.lock)",
      "Read(**/Gemfile.lock)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/session-init.sh\"'"
          },
          {
            "type": "command",
            "command": "/Users/axos-agallentes/homebrew/bin/node /Users/axos-agallentes/homebrew/lib/node_modules/context-mode/hooks/sessionstart.mjs"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/instructions-loaded.sh\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write|Grep|Glob|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/pre-tool-gate-v2.sh\"'"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/axos-agallentes/homebrew/bin/node /Users/axos-agallentes/homebrew/lib/node_modules/context-mode/hooks/pretooluse.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/post-tool-analytics.sh\"'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/prompt-score-commit.sh\"'"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/axos-agallentes/homebrew/bin/node /Users/axos-agallentes/homebrew/lib/node_modules/context-mode/hooks/posttooluse.mjs"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/context-monitor.sh\"'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/qmd-sync.sh\"'"
          },
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/plans-healthcheck.sh\"'"
          },
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/prompt-parallelism-hint.sh\"'"
          },
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/plan-todowrite-reminder.sh\"'"
          },
          {
            "type": "command",
            "command": "/Users/axos-agallentes/homebrew/bin/node /Users/axos-agallentes/homebrew/lib/node_modules/context-mode/hooks/userpromptsubmit.mjs"
          },
          {
            "type": "command",
            "command": "bash -lc '$HOME/.dotfiles/tmux/scripts/claude-tmux-bridge.sh activity-start'"
          },
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/prompt-capture.sh\"'"
          },
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/prompt-score-correction.sh\"'"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/pre-compact.sh\"'"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/axos-agallentes/homebrew/bin/node /Users/axos-agallentes/homebrew/lib/node_modules/context-mode/hooks/precompact.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/session-end.sh\"'"
          },
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/plan-completion-check.sh\"'"
          },
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/feedback-capture.sh\"'"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/todo-gate.sh\"'"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/worktree-create.sh\"'"
          },
          {
            "type": "command",
            "command": "bash -lc '$HOME/.dotfiles/tmux/scripts/claude-tmux-bridge.sh worktree-enter'"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$HOME/.dotfiles/.claude/hooks/worktree-remove.sh\"'"
          },
          {
            "type": "command",
            "command": "bash -lc '$HOME/.dotfiles/tmux/scripts/claude-tmux-bridge.sh worktree-exit'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/claude-statusline/statusline.sh --format '%model% ▸ %percent% (%remaining%) ▸ Cache: %cache_hit% ▸ %time% ▸ %project%'"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "bash-language-server@claude-code-lsps": true
  },
  "extraKnownMarketplaces": {},
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "advisorModel": "opus",
  "plansDirectory": "./plans",
  "skipDangerousModePermissionPrompt": true,
  "autoMode": {
    "environment": [
      "Organization: Axos Financial / Axos Bank. Primary use: software development.",
      "Source control: dev.azure.com/bofaz and bofaz.visualstudio.com — all repos and projects under these organizations.",
      "Key projects: Axos-Universal-Core, Axos Clearing, Axos Core Services, Axos-Crypto-Core, AAS, AxPay, AxTrader, Stock Lending Services.",
      "Azure DevOps CLI org: https://dev.azure.com/bofaz. PR creation org: https://bofaz.visualstudio.com.",
      "Local development: macOS, git worktrees under .trees/, homebrew at /Users/axos-agallentes/homebrew/."
    ]
  },
  "compactCustomInstructions": "After compaction, immediately re-read plans/active-context.md before doing anything else — it is the authoritative resume point. Do not waste summary tokens on content already captured in plans/ files (active-context.md, decisions.md, progress.md) — those files persist on disk and will be re-read. Focus the summary on: in-flight tool call results not yet written to disk, ephemeral error messages, and any decisions made verbally that have not been recorded. Always preserve: current branch name, uncommitted file list, active plan file path, and the exact task being worked on at the moment of compaction.",
  "autoCompact": true
}
