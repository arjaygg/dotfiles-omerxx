{
  "env": {
    "USE_BUILTIN_RIPGREP": "0"
  },
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "TaskCreate(*)",
      "TaskGet(*)",
      "TaskList(*)",
      "TaskOutput(*)",
      "TaskStop(*)",
      "TaskUpdate(*)",
      "mcp__serena__*",
      "mcp__qmd__*",
      "mcp__claude-in-chrome__*",
      "mcp__*__*"
    ]
  },
  "model": "sonnet",
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/claude-statusline/statusline.sh"
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": false,
    "osgrep@osgrep": false,
    "gopls-lsp@claude-plugins-official": true,
    "gopls@claude-code-lsps": true,
    "claude-md-management@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "claude-mem@thedotmack": false,
    "skill-creator@claude-plugins-official": false
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash ~/.dotfiles/.claude/hooks/pre-tool-gate.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.dotfiles/.claude/hooks/post-tool-handler.sh" }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "bash ~/.dotfiles/.claude/hooks/context-monitor.sh" }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "bash ~/.dotfiles/.claude/hooks/pre-compact.sh" }
        ]
      }
    ]
  }
}
