#!/usr/bin/env bash

# Unified PR stack CLI (Charcoal + worktrees)
#
# This is the entrypoint that Claude "stack-*" skills expect.
# It routes to `.claude/scripts/pr-stack/*` implementations and worktree helpers.

set -euo pipefail

STACK_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PR_STACK_DIR="$STACK_SCRIPT_DIR/pr-stack"
PR_STACK_LIB_DIR="$PR_STACK_DIR/lib"

die() {
  echo "ERROR: $*" >&2
  exit 1
}

require_git_repo() {
  git rev-parse --git-dir >/dev/null 2>&1 || die "Not in a git repository"
}

default_trunk_branch() {
  local trunk=""
  trunk="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || true)"
  if [ -n "$trunk" ]; then
    echo "$trunk"
    return 0
  fi
  if git rev-parse --verify main >/dev/null 2>&1; then
    echo "main"
    return 0
  fi
  echo "master"
}

load_libs() {
  # Shellcheck: these are local, repo-managed scripts.
  # shellcheck disable=SC1090
  if [ -f "$PR_STACK_LIB_DIR/validation.sh" ]; then
    source "$PR_STACK_LIB_DIR/validation.sh"
  fi
  # shellcheck disable=SC1090
  if [ -f "$PR_STACK_LIB_DIR/charcoal-compat.sh" ]; then
    source "$PR_STACK_LIB_DIR/charcoal-compat.sh"
  fi
  # shellcheck disable=SC1090
  if [ -f "$PR_STACK_LIB_DIR/worktree-charcoal.sh" ]; then
    source "$PR_STACK_LIB_DIR/worktree-charcoal.sh"
  fi
  # shellcheck disable=SC1090
  if [ -f "$PR_STACK_LIB_DIR/doctor.sh" ]; then
    source "$PR_STACK_LIB_DIR/doctor.sh"
  fi
}

print_usage() {
  cat <<'EOF'
Usage: .claude/scripts/stack <command> [args]

Core commands:
  init [trunk]                  Initialize Charcoal (gt) in this repo
  create <branch> [base] [-w]    Create stacked branch (optionally with worktree)
  status [--verbose] [--ci]      Show PR stack (includes worktree view when possible)
  up                             Navigate to parent (worktree-aware; use eval)
  down [index]                   Navigate to child (worktree-aware; use eval)
  restack                        Restack via Charcoal and sync worktrees
  update [merged-branch]         Update stack after merge (rebases dependents)
  pr <branch> [target] [title]   Create Azure DevOps PR
  merge <pr-id>                  Merge PR and update dependent branches
  doctor [--fix]                 Diagnose stack health

Worktree commands:
  worktree-add <branch>          Add worktree for existing branch under .trees/
  worktree-list                  List worktrees
  worktree-remove <path>         Remove a worktree (refuses if dirty)

Tips:
  eval $(.claude/scripts/stack up)
  eval $(.claude/scripts/stack down)
EOF
}

cmd_init() {
  require_git_repo
  load_libs

  local trunk="${1:-}"
  if [ -z "$trunk" ]; then
    trunk="$(default_trunk_branch)"
  fi

  charcoal_init "$trunk"
}

cmd_status() {
  require_git_repo
  load_libs

  # First: show worktree-aware Charcoal view (when possible)
  if type wt_stack_status >/dev/null 2>&1 && type charcoal_initialized >/dev/null 2>&1 && charcoal_initialized; then
    wt_stack_status || true
    echo ""
    echo "────────────────────────────────────────────────────────────"
    echo ""
  fi

  exec "$PR_STACK_DIR/list-stack.sh" "$@"
}

cmd_up() {
  require_git_repo
  load_libs
  type wt_charcoal_up >/dev/null 2>&1 || die "Missing worktree-charcoal integration"
  wt_charcoal_up
}

cmd_down() {
  require_git_repo
  load_libs
  type wt_charcoal_down >/dev/null 2>&1 || die "Missing worktree-charcoal integration"
  wt_charcoal_down "${1:-0}"
}

cmd_restack() {
  require_git_repo
  load_libs
  type wt_charcoal_restack >/dev/null 2>&1 || die "Missing worktree-charcoal integration"
  wt_charcoal_restack
}

cmd_worktree_remove() {
  require_git_repo

  local path="${1:-}"
  [ -n "$path" ] || die "worktree-remove requires a path"

  local abs_path
  abs_path="$(cd "$path" 2>/dev/null && pwd)" || die "Path does not exist: $path"

  local cwd
  cwd="$(pwd)"
  if [ "$abs_path" = "$cwd" ]; then
    die "Refusing to remove the current directory worktree"
  fi

  local status
  status="$(git -C "$abs_path" status --short 2>/dev/null || true)"
  if [ -n "$status" ]; then
    echo "Refusing to remove worktree with uncommitted changes:" >&2
    echo "$status" >&2
    exit 1
  fi

  git worktree remove "$abs_path"
}

main() {
  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    ""|-h|--help|help)
      print_usage
      ;;
    init)
      cmd_init "$@"
      ;;
    create)
      exec "$PR_STACK_DIR/create-stack.sh" "$@"
      ;;
    status)
      cmd_status "$@"
      ;;
    up)
      cmd_up "$@"
      ;;
    down)
      cmd_down "$@"
      ;;
    restack)
      cmd_restack "$@"
      ;;
    update)
      exec "$PR_STACK_DIR/update-stack.sh" "$@"
      ;;
    pr)
      exec "$PR_STACK_DIR/create-pr.sh" "$@"
      ;;
    merge)
      exec "$PR_STACK_DIR/merge-stack.sh" "$@"
      ;;
    doctor)
      require_git_repo
      load_libs
      type doctor_main >/dev/null 2>&1 || die "Missing doctor integration"
      doctor_main "${1:-}"
      ;;
    worktree-add)
      require_git_repo
      load_libs
      type wt_add_for_branch >/dev/null 2>&1 || die "Missing worktree-charcoal integration"
      wt_add_for_branch "${1:-}"
      ;;
    worktree-list)
      require_git_repo
      git worktree list
      ;;
    worktree-remove)
      cmd_worktree_remove "$@"
      ;;
    *)
      print_usage >&2
      die "Unknown command: $cmd"
      ;;
  esac
}

main "$@"
