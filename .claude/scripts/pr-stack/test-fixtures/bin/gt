#!/usr/bin/env bash
set -euo pipefail

# Minimal stub for Charcoal/Graphite `gt` used by e2e tests.
# Uses `.git/.graphite_repo_config` as "initialized" marker and stores
# parent relationships in a simple file under the common git dir.

cmd="${1:-}"
shift || true

ensure_repo() {
  git rev-parse --git-dir >/dev/null 2>&1 || { echo "gt: not a git repo" >&2; exit 1; }
}

git_common_dir() {
  git rev-parse --git-common-dir 2>/dev/null || git rev-parse --git-dir
}

parents_file() {
  # Use common dir so it works from worktrees too.
  local gdir
  gdir="$(git rev-parse --git-common-dir 2>/dev/null || git rev-parse --git-dir 2>/dev/null || true)"
  if [ -n "$gdir" ]; then
    echo "$gdir/gt-parents"
  fi
}

get_parent() {
  local b="$1"
  local pf
  pf="$(parents_file)"
  if [ -n "$pf" ] && [ -f "$pf" ]; then
    awk -F: -v b="$b" '$1==b {print $2; exit}' "$pf" || true
  fi
}

set_parent() {
  local b="$1"
  local p="$2"
  local pf tmp
  pf="$(parents_file)"
  [ -n "$pf" ] || return 0
  mkdir -p "$(dirname "$pf")"
  tmp="${pf}.tmp"
  if [ -f "$pf" ]; then
    awk -F: -v b="$b" '$1!=b {print $0}' "$pf" > "$tmp" || true
  else
    : > "$tmp"
  fi
  echo "$b:$p" >> "$tmp"
  mv "$tmp" "$pf"
}

list_children() {
  local p="$1"
  local pf
  pf="$(parents_file)"
  if [ -n "$pf" ] && [ -f "$pf" ]; then
    awk -F: -v p="$p" '$2==p {print $1}' "$pf" | sort
  fi
}

case "$cmd" in
  --version|version)
    echo "gt 0.0.0-test-stub"
    ;;

  repo)
    sub="${1:-}"
    shift || true
    case "$sub" in
      init)
        ensure_repo
        # Mark initialized the way our scripts detect it.
        gdir="$(git_common_dir)"
        : > "$gdir/.graphite_repo_config"
        exit 0
        ;;
      *)
        echo "gt stub: unsupported: repo $sub" >&2
        exit 2
        ;;
    esac
    ;;

  branch)
    sub="${1:-}"
    shift || true
    case "$sub" in
      info)
        ensure_repo
        b="${1:-$(git branch --show-current)}"
        parent="$(get_parent "$b" || true)"
        echo "Branch: $b"
        if [ -n "$parent" ]; then
          echo "Parent: $parent"
        else
          echo "Parent:"
        fi
        ;;
      track)
        ensure_repo
        b="${1:-}"
        shift || true
        [ -n "$b" ] || { echo "gt stub: branch track requires name" >&2; exit 2; }
        parent=""
        while [ $# -gt 0 ]; do
          case "${1:-}" in
            --parent)
              parent="${2:-}"
              shift 2 || true
              ;;
            *)
              shift || true
              ;;
          esac
        done
        [ -n "$parent" ] || { echo "gt stub: branch track requires --parent" >&2; exit 2; }
        set_parent "$b" "$parent"
        exit 0
        ;;
      create)
        ensure_repo
        b="${1:-}"
        [ -n "$b" ] || { echo "gt stub: branch create requires name" >&2; exit 2; }
        git checkout -b "$b" >/dev/null
        ;;
      untrack)
        exit 0
        ;;
      *)
        echo "gt stub: unsupported: branch $sub" >&2
        exit 2
        ;;
    esac
    ;;

  log)
    sub="${1:-}"
    shift || true
    case "$sub" in
      short)
        ensure_repo
        # Print a simple tree from tracked parent relationships.
        trunk="${GT_TRUNK:-main}"
        echo "$trunk"
        print_subtree() {
          local node="$1"
          local prefix="$2"
          local is_last="$3"
          if [ "$is_last" = "true" ]; then
            echo "${prefix}└── ${node}"
            child_prefix="${prefix}    "
          else
            echo "${prefix}├── ${node}"
            child_prefix="${prefix}│   "
          fi

          mapfile -t kids < <(list_children "$node")
          if [ "${#kids[@]}" -gt 0 ]; then
            local i=0
            local last_idx=$((${#kids[@]} - 1))
            for kid in "${kids[@]}"; do
              if [ "$i" -eq "$last_idx" ]; then
                print_subtree "$kid" "$child_prefix" "true"
              else
                print_subtree "$kid" "$child_prefix" "false"
              fi
              i=$((i + 1))
            done
          fi
        }

        mapfile -t roots < <(list_children "$trunk")
        if [ "${#roots[@]}" -gt 0 ]; then
          i=0
          last_idx=$((${#roots[@]} - 1))
          for r in "${roots[@]}"; do
            if [ "$i" -eq "$last_idx" ]; then
              print_subtree "$r" "" "true"
            else
              print_subtree "$r" "" "false"
            fi
            i=$((i + 1))
          done
        fi
        ;;
      *)
        echo "gt stub: unsupported: log $sub" >&2
        exit 2
        ;;
    esac
    ;;

  up)
    ensure_repo
    b="$(git branch --show-current)"
    parent="$(get_parent "$b" || true)"
    [ -n "$parent" ] || { echo "gt stub: no parent" >&2; exit 1; }
    git checkout "$parent" >/dev/null
    ;;

  down)
    ensure_repo
    idx="${1:-0}"
    b="$(git branch --show-current)"
    mapfile -t kids < <(list_children "$b")
    [ "${#kids[@]}" -gt 0 ] || { echo "gt stub: no child" >&2; exit 1; }
    kid="${kids[$idx]:-}"
    [ -n "$kid" ] || { echo "gt stub: invalid child index" >&2; exit 1; }
    git checkout "$kid" >/dev/null
    ;;

  stack)
    sub="${1:-}"
    shift || true
    case "$sub" in
      restack)
        # Stub: assume clean restack.
        exit 0
        ;;
      *)
        echo "gt stub: unsupported: stack $sub" >&2
        exit 2
        ;;
    esac
    ;;

  restack)
    # Stub: assume clean restack.
    exit 0
    ;;

  *)
    echo "gt stub: unsupported: $cmd" >&2
    exit 2
    ;;
esac

