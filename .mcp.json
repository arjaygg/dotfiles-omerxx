{
  "mcpServers": {
    "pctx": {
      "command": "/Users/axos-agallentes/homebrew/bin/pctx",
      "args": [
        "mcp",
        "start",
        "--stdio",
        "-c",
        "/Users/axos-agallentes/.config/pctx/pctx.json"
      ],
      "env": {}
    },
    "context-mode": {
      "command": "context-mode"
    },
    "notebooklm": {
      "command": "notebooklm-mcp",
      "args": []
    },
    "exa": {
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server",
        "--tools=web_search_exa,deep_search_exa,get_code_context_exa,crawling_exa,company_research_exa,linkedin_search_exa,deep_researcher_start,deep_researcher_check"
      ]
    },
    "qmd": {
      "command": "qmd",
      "args": [
        "mcp"
      ]
    },
    "repomix": {
      "command": "repomix",
      "args": [
        "--mcp"
      ]
    }
  }
}
