[
  {
    "name": "bash-git-status-allowed",
    "expect": "allow",
    "input": {
      "tool_name": "Bash",
      "tool_input": {"command": "git status --short"}
    }
  },
  {
    "name": "bash-grep-blocked",
    "expect": "deny",
    "input": {
      "tool_name": "Bash",
      "tool_input": {"command": "grep -r WorkerPool pkg/"}
    }
  },
  {
    "name": "glob-specific-file-allowed",
    "expect": "allow",
    "input": {
      "tool_name": "Glob",
      "tool_input": {"pattern": "pkg/worker/pool.go"}
    }
  },
  {
    "name": "grep-capitalized-symbol-blocked",
    "expect": "deny",
    "input": {
      "tool_name": "Grep",
      "tool_input": {"pattern": "WorkerPool"}
    }
  },
  {
    "name": "grep-empty-tool-name-blocked",
    "expect": "deny",
    "input": {
      "tool_name": "",
      "tool_input": {"pattern": "anything"}
    }
  },
  {
    "name": "grep-general-pattern-blocked",
    "expect": "deny",
    "input": {
      "tool_name": "Grep",
      "tool_input": {"pattern": "error handling"}
    }
  },
  {
    "name": "grep-symbol-pattern-blocked",
    "expect": "deny",
    "input": {
      "tool_name": "Grep",
      "tool_input": {"pattern": "^WorkerPool$"}
    }
  }
]
